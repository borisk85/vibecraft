# -----------------------------------------------------------------------
# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.
# -----------------------------------------------------------------------

# Claude API (Anthropic) — required for /api/calculator and /api/chat
ANTHROPIC_API_KEY=

# Resend — transactional email after calculator submission
RESEND_API_KEY=

# Upstash Redis — rate limiting on AI endpoints (5 req/hour per IP)
# Created automatically when you connect Upstash via Vercel Marketplace.
# Both prefixes are supported (KV_* and UPSTASH_*).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Telegram — lead notifications from contact form and calculator
# 1. Create a bot via @BotFather, copy the token
# 2. Message the bot, then get your chat_id from:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Supabase — blog admin, auth, waitlist
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin allowlist — ОБЯЗАТЕЛЬНО задать на Vercel. Только эти емейлы попадают в /admin
# (вход по magic-link + проверка по списку). Пусто = в админку не пускает НИКОГО
# (fail-closed). Несколько — через запятую.
ADMIN_EMAILS=

# Analytics (optional — scripts are skipped if empty)
NEXT_PUBLIC_YM_ID=
NEXT_PUBLIC_GA_ID=

# Site base URL — used in sitemap, JSON-LD, OG tags
# Prod: https://vibecraft.kz
# Leave empty for Vercel preview deployments (falls back to prod)
NEXT_PUBLIC_SITE_URL=
