# Telegram — для приема заявок с формы FinalCTA
# 1. Создайте бота через @BotFather, скопируйте токен
# 2. Напишите этому боту в личку, затем узнайте chat_id через:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Аналитика (опционально — если пусто, скрипты не подключаются)
NEXT_PUBLIC_YM_ID=
NEXT_PUBLIC_GA_ID=

# Базовый URL сайта — подставляется в siteConfig, sitemap, JSON-LD, OG.
# Prod: https://vibecraft.kz
# Vercel preview: URL деплоя (можно оставить пустым — будет fallback на prod)
NEXT_PUBLIC_SITE_URL=

# Supabase — для /audit waitlist.
# Project URL публичный, service_role key СЕРВЕРНЫЙ (не NEXT_PUBLIC_)
# и хранится только в .env.local / Vercel Project Settings.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
